---
import studio from '@/data/services.json';
---

<section class="about" id="acerca">
  <div class="about__container">
    <h2 class="about__heading">Sobre Mí</h2>
    <div class="about__content">
      <div class="about__photo">
        <img
          src="/images/noemi-retrato.jpg"
          alt="Noemi Parrales — especialista en belleza en Piura"
          class="about__photo-img"
          width="250"
          height="250"
        />
      </div>
      <div class="about__text">
        <p>
          Profesional certificada y con experiencia en manicura, pedicura, pestañas, diseño de cejas
          y maquillaje profesional dedicada a realzar la belleza natural de cada clienta con técnicas
          precisas, productos de alta gama y herramientas previamente esterilizadas.
        </p>
        <p>
          Mi objetivo es lograr que cada clienta se sienta única y radiante, además de ofrecerles
          un espacio seguro y confortable donde cada detalle se cuida para que te veas y te sientas
          bella, consentida y confiada.
        </p>
        <p>
          He trabajado en Barcelona — España por más de un año y ahora ofrezco mis servicios en
          Castilla — Piura — Perú en mi beauty studio, la atención es personalizada y con previa cita.
        </p>

      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 5rem 1.5rem;
    background: white;
  }

  .about__container {
    max-width: 800px;
    margin: 0 auto;
  }

  .about__heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 300;
    margin: 0 0 3rem;
    color: #3d2b3d;
  }

  .about__content {
    display: flex;
    gap: 3rem;
    align-items: center;
  }

  .about__photo {
    flex-shrink: 0;
  }

  .about__photo-img {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #ede4ed;
  }

  .about__text {
    flex: 1;
  }

  .about__text p {
    color: #6b4c6b;
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 1rem;
  }



  @media (max-width: 600px) {
    .about__content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
