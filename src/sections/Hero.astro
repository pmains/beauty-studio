---
import studio from '@/data/services.json';

const waUrl = studio.studio.whatsappUrl + "?text=" + encodeURIComponent(studio.studio.whatsappMessage);
---

<section class="hero">
  <div class="hero__bg"></div>
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">
      <span class="hero__subtitle">Noemi Parrales</span>
      Beauty Studio
    </h1>
    <p class="hero__tagline">
      Manicura, pedicura, maquillaje profesional y diseño de cejas en Castilla, Piura.
      Studio en casa con cita previa — atención personalizada.
    </p>
    <div class="hero__actions">
      <a href={waUrl} class="hero__cta hero__cta--primary" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Reserva tu cita
      </a>
      <a href="#servicios" class="hero__cta hero__cta--secondary">
        Ver servicios
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    color: white;
    text-align: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/hero-bg.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(26, 15, 26, 0.8) 0%,
      rgba(26, 15, 26, 0.55) 50%,
      rgba(26, 15, 26, 0.8) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding: 2rem;
    max-width: 700px;
  }

  .hero__title {
    font-size: 3rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .hero__subtitle {
    display: block;
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #ede4ed;
    margin-bottom: 0.75rem;
  }

  .hero__tagline {
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 auto 2rem;
    max-width: 520px;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .hero__cta:hover {
    transform: translateY(-2px);
  }

  .hero__cta--primary {
    background: #25d366;
    color: white;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
  }

  .hero__cta--primary:hover {
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
  }

  .hero__cta--secondary {
    background: rgba(237, 228, 237, 0.25);
    color: white;
    backdrop-filter: blur(4px);
  }

  .hero__cta--secondary:hover {
    background: rgba(237, 228, 237, 0.4);
  }
</style>
