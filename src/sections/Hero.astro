---
import studio from '@/data/services.json';

const waUrl = studio.studio.whatsappUrl + "?text=" + encodeURIComponent(studio.studio.whatsappMessage);
---

<section class="hero">
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">
      <span class="hero__subtitle">Noemi Parrales</span>
      Beauty Studio
    </h1>
    <p class="hero__tagline">
      Manicura, pedicura, maquillaje profesional y diseño de cejas en Castilla, Piura.
      Studio en casa con cita previa — atención personalizada.
    </p>
    <div class="hero__actions">
      <a href="#servicios" class="hero__cta hero__cta--secondary">
        Ver servicios
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background-image: url('/images/hero-image-noemi.jpg');
    background-size: cover;
    background-position: center 90px;
    background-repeat: no-repeat;
    color: white;
    text-align: center;
    overflow: hidden;
  }



  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(26, 15, 26, 0.85) 0%,
      rgba(26, 15, 26, 0.65) 50%,
      rgba(26, 15, 26, 0.85) 100%
    );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    padding: 2rem;
    max-width: 700px;
  }

  .hero__title {
    font-size: 3rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .hero__subtitle {
    display: block;
    font-family: "Playfair Display", Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.3rem;
    letter-spacing: 0.12em;
    color: #ede4ed;
    margin-bottom: 0.75rem;
  }

  .hero__tagline {
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 auto 2rem;
    max-width: 520px;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .hero__cta:hover {
    transform: translateY(-2px);
  }

  .hero__cta--primary {
    background: #25d366;
    color: white;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
  }

  .hero__cta--primary:hover {
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
  }

  .hero__cta--secondary {
    background: rgba(237, 228, 237, 0.25);
    color: white;
    backdrop-filter: blur(4px);
  }

  .hero__cta--secondary:hover {
    background: rgba(237, 228, 237, 0.4);
  }
</style>
