---
const images = [
  { src: "/images/cejas-antes-despues-1.jpg", alt: "Antes y después de diseño de cejas - Noemi Parrales Beauty Studio", category: "Cejas" },
  { src: "/images/cejas-antes-despues-2.jpg", alt: "Antes y después de cejas perfiladas - Noemi Parrales Beauty Studio", category: "Cejas" },
  { src: "/images/cejas-antes-despues-3.jpg", alt: "Transformación de cejas antes y después - Noemi Parrales", category: "Cejas" },
  { src: "/images/cejas-antes-despues-4.jpg", alt: "Diseño de cejas antes y después - Noemi Parrales Piura", category: "Cejas" },
  { src: "/images/cejas-antes-despues-5.jpg", alt: "Cejas definidas antes y después - Noemi Parrales Beauty Studio", category: "Cejas" },
  { src: "/images/maquillaje-antes-despues-1.jpg", alt: "Maquillaje profesional antes y después - Noemi Parrales Piura", category: "Maquillaje" },
];
---

<section class="gallery" id="galeria">
  <div class="gallery__container">
    <h2 class="gallery__heading">Nuestro Trabajo</h2>
    <p class="gallery__subtext">Resultados reales de nuestros servicios. ¡Contáctanos para lograr tu mejor versión!</p>

    <div class="gallery__grid">
      {images.map((img) => (
        <div class="gallery__item">
          <img
            src={img.src}
            alt={img.alt}
            class="gallery__img"
            loading="lazy"
            width="384"
            height="384"
          />
          <span class="gallery__category">{img.category}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    padding: 5rem 1.5rem;
    background: #faf5f7;
  }

  .gallery__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .gallery__heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 300;
    margin: 0 0 0.5rem;
    color: #3d2b3d;
  }

  .gallery__subtext {
    text-align: center;
    color: #9e7a9e;
    font-size: 0.95rem;
    margin: 0 0 3rem;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .gallery__item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(61, 43, 61, 0.06);
    transition: transform 0.2s;
  }

  .gallery__item:hover {
    transform: translateY(-3px);
  }

  .gallery__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gallery__category {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: "Playfair Display", Georgia, serif;
    font-style: italic;
    background: rgba(61, 43, 61, 0.85);
    color: #ede4ed;
    padding: 0.25rem 0.7rem;
    border-radius: 15px;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.03em;
  }
</style>
