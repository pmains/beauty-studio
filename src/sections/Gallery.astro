const images = [];
---

<section class="gallery" id="galeria">
  <div class="gallery__container">
    <h2 class="gallery__heading">Nuestro Trabajo</h2>
    <p class="gallery__subtext">Próximamente — galería completa de nuestros trabajos.</p>
  </div>
</section>

<style>
  .gallery {
    padding: 5rem 1.5rem;
    background: #faf5f7;
  }

  .gallery__container {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .gallery__heading {
    font-size: 2rem;
    font-weight: 300;
    margin: 0 0 0.5rem;
    color: #3d2b3d;
  }

  .gallery__subtext {
    color: #9e7a9e;
    font-size: 0.95rem;
    margin: 0;
  }
</style>
