---
const highlights = [
  { src: "/images/maquillaje/maquillaje-novia-bridal-piura-2.jpg", label: "Maquillaje", link: "/maquillaje/" },
  { src: "/images/pestanas/pestanas-03.jpg", label: "Pestañas", link: "/pestanas/" },
  { src: "/images/Cejas/cejas-07.jpg", label: "Cejas", link: "/cejas/" },
  { src: "/images/unas-naturales/unas-naturales-11.jpg", label: "Uña Natural", link: "/manicura/" },
  { src: "/images/extensiones/extensiones-01.jpg", label: "Extensiones", link: "/unas-extension/" },
  { src: "/images/Pedicura/pedicura-03.jpg", label: "Pedicura", link: "/pedicura/" },
];
---

<section class="gallery" id="galeria">
  <div class="gallery__container">
    <h2 class="gallery__heading">Nuestro Trabajo</h2>
    <p class="gallery__subtext">Resultados reales de nuestros servicios en Piura.</p>

    <div class="gallery__grid">
      {highlights.map((img) => (
        <a href={img.link} class="gallery__item">
          <img src={img.src} alt={img.label + " - Noemi Parrales Beauty Studio"} class="gallery__img" loading="lazy" width="400" height="400" />
          <span class="gallery__label">{img.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    padding: 5rem 1.5rem;
    background: #faf5f7;
  }

  .gallery__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .gallery__heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 300;
    margin: 0 0 0.5rem;
    color: #3d2b3d;
  }

  .gallery__subtext {
    text-align: center;
    color: #9e7a9e;
    font-size: 0.95rem;
    margin: 0 0 3rem;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .gallery__item {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    box-shadow: 0 2px 10px rgba(61, 43, 61, 0.06);
    transition: transform 0.2s;
  }

  .gallery__item:hover {
    transform: translateY(-3px);
  }

  .gallery__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gallery__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(61, 43, 61, 0.85));
    color: white;
    font-family: "Playfair Display", Georgia, serif;
    font-style: italic;
    padding: 2rem 1rem 0.75rem;
    font-size: 1rem;
  }
</style>
