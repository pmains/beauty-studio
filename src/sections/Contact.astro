---
import studio from '@/data/services.json';

const waUrl = studio.studio.whatsappUrl + "?text=" + encodeURIComponent(studio.studio.whatsappMessage);
---

<section class="contact" id="contacto">
  <div class="contact__container">
    <h2 class="contact__heading">Contáctanos</h2>
    <p class="contact__subtext">
      Reserva tu cita por WhatsApp o llámame directamente.
      Atiendo con cita previa en Urb. El Bosque, Castilla — Piura.
    </p>

    <div class="contact__methods">
      <a
        href={waUrl}
        class="contact__card contact__card--whatsapp"
        target="_blank"
        rel="noopener"
      >
        <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span class="contact__card-label">Reservar por WhatsApp</span>
        <span class="contact__card-detail">{studio.studio.phoneDisplay}</span>
      </a>

      <a href={`tel:${studio.studio.phone}`} class="contact__card contact__card--call">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        <span class="contact__card-label">Llamar ahora</span>
        <span class="contact__card-detail">{studio.studio.phoneDisplay}</span>
      </a>

      <a href={`mailto:${studio.studio.email}`} class="contact__card contact__card--email">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
        <span class="contact__card-label">Enviar correo</span>
        <span class="contact__card-detail">{studio.studio.email}</span>
      </a>
    </div>

    <div class="contact__info">
      <div class="contact__info-block">
        <h3>Horario</h3>
        <p>{studio.studio.hours.weekdays}</p>
        {studio.studio.hours.saturday && <p>{studio.studio.hours.saturday}</p>}
        <p class="contact__note">{studio.studio.hours.sunday}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 5rem 1.5rem;
    background: white;
  }

  .contact__container {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .contact__heading {
    font-size: 2rem;
    font-weight: 300;
    margin: 0 0 0.5rem;
    color: #3d2b3d;
  }

  .contact__subtext {
    color: #9e7a9e;
    margin: 0 0 3rem;
    font-size: 0.95rem;
  }

  .contact__methods {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact__card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    color: white;
    transition: transform 0.2s, box-shadow 0.2s;
    text-align: left;
  }

  .contact__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
  }

  .contact__card--whatsapp {
    background: #25d366;
  }

  .contact__card--call {
    background: #3d2b3d;
  }

  .contact__card--email {
    background: #6b4c6b;
  }

  .contact__card-label {
    font-weight: 600;
    font-size: 1rem;
  }

  .contact__card-detail {
    margin-left: auto;
    font-size: 0.85rem;
    opacity: 0.85;
  }

  .contact__info {
    margin-top: 3rem;
    text-align: center;
  }

  .contact__info-block h3 {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #3d2b3d;
    margin: 0 0 0.5rem;
  }

  .contact__info-block p {
    color: #6b4c6b;
    font-size: 0.95rem;
    margin: 0.2rem 0;
  }

  .contact__note {
    color: #9e7a9e;
    font-size: 0.8rem !important;
    margin-top: 0.3rem;
  }

  .contact__location {
    margin-top: 2rem;
    color: #9e7a9e;
    font-size: 0.95rem;
  }

  @media (max-width: 500px) {
    .contact__card {
      flex-direction: column;
      text-align: center;
    }

    .contact__card-detail {
      margin-left: 0;
    }
  }
</style>
