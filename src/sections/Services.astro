---
import studio from '@/data/services.json';
import ServiceCard from '@/components/ServiceCard.astro';
---

<section class="services" id="servicios">
  <div class="services__container">
    <h2 class="services__heading">Nuestros Servicios</h2>
    <p class="services__subtext">
      Todos los precios en {studio.studio.currency} — Reserva por WhatsApp y asegura tu hora.
    </p>

    <div class="services__grid">
      {
        studio.categories.map((category) => (
          <div class="services__category">
            <h3 class="services__category-title">{category.name}</h3>
            <div class="services__list">
              {category.services.map((service) => (
                <ServiceCard name={service.name} price={service.price} />
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="services__cta">
      <a href={studio.studio.whatsappUrl + "?text=" + encodeURIComponent(studio.studio.whatsappMessage)} class="services__cta-link" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Reserva tu cita por WhatsApp
      </a>
    </div>

    <div class="services__highlights">
      {studio.highlights.map((h) => (
        <div class="services__highlight">
          <h4>{h.title}</h4>
          <p>{h.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 5rem 1.5rem;
    background: #faf5f7;
  }

  .services__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .services__heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 300;
    margin: 0 0 0.5rem;
    color: #3d2b3d;
  }

  .services__subtext {
    text-align: center;
    color: #9e7a9e;
    font-size: 0.95rem;
    margin: 0 0 3rem;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .services__category {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(61, 43, 61, 0.06);
  }

  .services__category-title {
    background: #3d2b3d;
    color: white;
    margin: 0;
    padding: 1rem 1.2rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .services__list {
    padding: 0.5rem 0;
  }

  .services__cta {
    text-align: center;
    margin: 2.5rem 0 0;
  }

  .services__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25d366;
    color: white;
    padding: 0.85rem 2.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, transform 0.2s;
  }

  .services__cta-link:hover {
    background: #1da851;
    transform: translateY(-2px);
  }

  .services__highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
    text-align: center;
  }

  .services__highlight h4 {
    color: #3d2b3d;
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .services__highlight p {
    color: #6b4c6b;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }
</style>
