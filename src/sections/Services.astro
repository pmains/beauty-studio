---
import studio from '@/data/services.json';
import ServiceCard from '@/components/ServiceCard.astro';
---

<section class="services" id="servicios">
  <div class="services__container">
    <h2 class="services__heading">Nuestros Servicios</h2>
    <p class="services__subtext">
      Todos los precios en {studio.studio.currency} — Reserva por WhatsApp y asegura tu hora.
    </p>

    <div class="services__grid services__grid--top">
      {
        studio.categories.slice(0, 3).map((category) => (
          <div class="services__category">
            <a href={"/" + category.slug + "/"} class="services__category-title">{category.name}</a>
            <div class="services__list">
              {category.services.map((service) => (
                <ServiceCard name={service.name} price={service.price} />
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <h3 class="services__divider">Nuestros Servicios en Uñas</h3>

    <div class="services__grid">
      {
        studio.categories.slice(3).map((category) => (
          <div class="services__category">
            <a href={"/" + category.slug + "/"} class="services__category-title">{category.name}</a>
            <div class="services__list">
              {category.services.map((service) => (
                <ServiceCard name={service.name} price={service.price} />
              ))}
            </div>
          </div>
        ))
      }
    </div>



    <div class="services__highlights">
      {studio.highlights.map((h) => (
        <div class="services__highlight">
          <h4>{h.title}</h4>
          <p>{h.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 5rem 1.5rem;
    background: #faf5f7;
  }

  .services__container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .services__heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 300;
    margin: 0 0 0.5rem;
    color: #3d2b3d;
  }

  .services__subtext {
    text-align: center;
    color: #9e7a9e;
    font-size: 0.95rem;
    margin: 0 0 3rem;
  }

  .services__divider {
    text-align: center;
    font-size: 1.3rem;
    font-weight: 400;
    color: #3d2b3d;
    margin: 2rem 0 1.5rem;
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .services__category {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(61, 43, 61, 0.06);
  }

  .services__category-title {
    display: block;
    background: #3d2b3d;
    color: white;
    text-decoration: none;
    margin: 0;
    padding: 1rem 1.2rem;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    transition: background 0.2s;
  }

  .services__category-title:hover {
    background: #6b4c6b;
  }

  .services__category-title::after {
    content: " →";
    opacity: 0.5;
  }

  .services__list {
    padding: 0.5rem 0;
  }

  .services__cta {
    text-align: center;
    margin: 2.5rem 0 0;
  }

  .services__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25d366;
    color: white;
    padding: 0.85rem 2.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, transform 0.2s;
  }

  .services__cta-link:hover {
    background: #1da851;
    transform: translateY(-2px);
  }

  .services__highlights {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
    text-align: center;
  }

  .services__highlight h4 {
    color: #3d2b3d;
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .services__highlight p {
    color: #6b4c6b;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }
</style>
