---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFAB from '@/components/WhatsAppFAB.astro';
import Watermark from '@/components/Watermark.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import studio from '@/data/services.json';
import '@/styles/global.css';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data, body } = entry;
const formalName = data.title.split(" en ")[0];

// Fetch related services (same category, excluding self)
const allServices = await getCollection('services');
const related = allServices
  .filter(s => s.data.serviceCategory === data.serviceCategory && s.data.slug !== data.slug)
  .slice(0, 3);

// Cross-category related (complementary)
const crossRelated = allServices
  .filter(s => s.data.serviceCategory !== data.serviceCategory)
  .slice(0, 2);

const waUrl = studio.studio.whatsappUrl + "?text=" + encodeURIComponent(
  `Hola Noemi, me interesa el servicio de ${formalName}. ¿Tienes disponibilidad?`
);

const breadcrumbLd = `{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://noemiparralesbeautystudio.com" },
    { "@type": "ListItem", "position": 2, "name": "${data.title}", "item": "https://noemiparralesbeautystudio.com/services/${data.slug}" }
  ]
}`;

const faqLd = `{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    ${data.faq.slice(0, 5).map((item) => `{
      "@type": "Question",
      "name": ${JSON.stringify(item.q)},
      "acceptedAnswer": { "@type": "Answer", "text": ${JSON.stringify(item.a)} }
    }`).join(',')}
  ]
}`;
---

<BaseLayout title={data.title} description={data.description}>
  <script set:html={breadcrumbLd} type="application/ld+json" slot="head"></script>
  <script set:html={faqLd} type="application/ld+json" slot="head"></script>

  <Header />

  <section class="service-hero">
    <div class="service-hero__overlay"></div>
    <div class="service-hero__content">
      <a href="/" class="service-hero__back">← Inicio</a>
      <nav class="service-hero__breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <span>{formalName}</span>
      </nav>
      <h1 class="service-hero__title">{data.title}</h1>
      <p class="service-hero__price">Desde {data.priceRange}</p>
    </div>
  </section>

  <section class="service-body">
    <div class="service-body__container">
      <h2>{formalName} en {data.city}</h2>
      <div class="service-body__content" set:html={body} />

    </div>
  </section>

  <section class="service-pricing" id="precios">
    <div class="service-pricing__container">
      <h2 class="service-pricing__heading">Precios</h2>
      <p class="service-pricing__subtext">{studio.studio.currency} — Reserva por WhatsApp</p>
      <div class="service-pricing__list">
        {data.pricing.map((s) => (
          <ServiceCard name={s.name} price={s.price} />
        ))}
      </div>
      <div class="service-pricing__cta">
        <a href={waUrl} class="service-pricing__cta-link" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Reserva tu cita
        </a>
      </div>
    </div>
  </section>

  <section class="service-faq" id="faq">
    <div class="service-faq__container">
      <h2 class="service-faq__heading">Preguntas Frecuentes</h2>
      <div class="service-faq__list">
        {data.faq.map((item) => (
          <div class="service-faq__item">
            <h3>{item.q}</h3>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="service-related">
    <div class="service-related__container">
      <h2>También te puede interesar</h2>
      <div class="service-related__grid">
        {related.concat(crossRelated).slice(0, 4).map((s) => (
          <a href={"/services/" + s.data.slug + "/"} class="service-related__card">
            <h3>{s.data.title}</h3>
            <p>{s.data.priceRange}</p>
          </a>
        ))}
      </div>

    </div>
  </section>

  <section class="service-contact">
    <div class="service-contact__container">
      <h2>¿Lista para tu cita?</h2>
      <p>Reserva por WhatsApp o llámame al {studio.studio.phoneDisplay}</p>
      <div class="service-contact__links">
        <a href={waUrl} class="service-contact__cta" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Reservar por WhatsApp
        </a>

      </div>
    </div>
  </section>

  <Footer />
  <Watermark />
  <WhatsAppFAB />
</BaseLayout>

<style>
  .service-hero {
    padding: 8rem 1.5rem 3rem;
    background: linear-gradient(135deg, rgba(26, 15, 26, 0.9) 0%, rgba(61, 43, 61, 0.7) 100%), url('/images/hero-bg.jpg') center/cover;
    color: white;
    text-align: center;
  }

  .service-hero__back {
    display: inline-block;
    color: #ede4ed;
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .service-hero__back:hover { opacity: 1; }

  .service-hero__breadcrumb {
    font-size: 0.8rem;
    color: #9e7a9e;
    margin-bottom: 1.5rem;
  }

  .service-hero__breadcrumb a {
    color: #ede4ed;
    text-decoration: none;
  }

  .service-hero__breadcrumb a:hover { opacity: 0.8; }

  .service-hero__breadcrumb span { margin: 0 0.3rem; }

  .service-hero__title {
    font-size: 2.2rem;
    font-weight: 300;
    margin: 0 0 0.75rem;
  }

  .service-hero__price {
    font-size: 1.1rem;
    color: #ede4ed;
    margin: 0;
  }

  .service-body {
    padding: 4rem 1.5rem;
    background: white;
  }

  .service-body__container {
    max-width: 700px;
    margin: 0 auto;
  }

  .service-body h2 {
    font-size: 1.5rem;
    font-weight: 400;
    color: #3d2b3d;
    margin: 0 0 1.5rem;
  }

  .service-body__content p {
    color: #6b4c6b;
    font-size: 1.05rem;
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .service-body__content a {
    color: #6b4c6b;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .service-body__content a:hover {
    color: #3d2b3d;
  }



  .service-pricing {
    padding: 4rem 1.5rem;
    background: #faf5f7;
  }

  .service-pricing__container {
    max-width: 550px;
    margin: 0 auto;
  }

  .service-pricing__heading {
    text-align: center;
    font-size: 1.8rem;
    font-weight: 300;
    color: #3d2b3d;
    margin: 0 0 0.5rem;
  }

  .service-pricing__subtext {
    text-align: center;
    color: #9e7a9e;
    font-size: 0.9rem;
    margin: 0 0 2rem;
  }

  .service-pricing__list {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(61, 43, 61, 0.06);
  }

  .service-pricing__cta {
    text-align: center;
    margin: 2rem 0 0;
  }

  .service-pricing__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25d366;
    color: white;
    padding: 0.85rem 2.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s, transform 0.2s;
  }

  .service-pricing__cta-link:hover {
    background: #1da851;
    transform: translateY(-2px);
  }

  .service-faq {
    padding: 4rem 1.5rem;
    background: white;
  }

  .service-faq__container {
    max-width: 700px;
    margin: 0 auto;
  }

  .service-faq__heading {
    text-align: center;
    font-size: 1.8rem;
    font-weight: 300;
    color: #3d2b3d;
    margin: 0 0 2.5rem;
  }

  .service-faq__item {
    padding: 1.2rem 0;
    border-bottom: 1px solid #ede4ed;
  }

  .service-faq__item:last-child { border-bottom: none; }

  .service-faq__item h3 {
    font-size: 1rem;
    font-weight: 600;
    color: #3d2b3d;
    margin: 0 0 0.4rem;
  }

  .service-faq__item p {
    color: #6b4c6b;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .service-contact {
    padding: 4rem 1.5rem;
    background: #faf5f7;
    text-align: center;
  }

  .service-contact__container {
    max-width: 500px;
    margin: 0 auto;
  }

  .service-contact h2 {
    font-size: 1.8rem;
    font-weight: 300;
    color: #3d2b3d;
    margin: 0 0 0.75rem;
  }

  .service-contact p {
    color: #9e7a9e;
    margin: 0 0 1.5rem;
  }

  .service-contact__links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .service-contact__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #25d366;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s, transform 0.2s;
  }

  .service-contact__cta:hover {
    background: #1da851;
    transform: translateY(-2px);
  }



  .service-related {
    padding: 4rem 1.5rem;
    background: white;
  }

  .service-related__container {
    max-width: 750px;
    margin: 0 auto;
    text-align: center;
  }

  .service-related h2 {
    font-size: 1.5rem;
    font-weight: 400;
    color: #3d2b3d;
    margin: 0 0 2rem;
  }

  .service-related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .service-related__card {
    display: block;
    padding: 1.2rem;
    background: #faf5f7;
    border-radius: 10px;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .service-related__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(61, 43, 61, 0.1);
  }

  .service-related__card h3 {
    font-family: "Inter", sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: #3d2b3d;
    margin: 0 0 0.3rem;
  }

  .service-related__card p {
    font-size: 0.85rem;
    color: #9e7a9e;
    margin: 0;
  }



</style>
